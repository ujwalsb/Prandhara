# =====================================================
# Prandhara ERP - SPA & API Routing (Hostinger hPanel)
# =====================================================
#
# NOTE: The working copy that gets deployed is at:
#   frontend/public/.htaccess
#
# Vite copies it to frontend/dist/.htaccess during build.
# This root-level copy is kept as a reference/backup.
#
# Hostinger serves files from the build output directory
# (frontend/dist), so this file may not be read by Apache
# if placed here. Upload it manually to the server's
# document root if needed.
# =====================================================

# Disable directory listing
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Do NOT rewrite API requests — let them reach the Node.js backend
  RewriteRule ^api/ - [L]

  # 2. Do NOT rewrite uploads
  RewriteRule ^uploads/ - [L]

  # 3. Do NOT rewrite existing files or directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule . - [L]

  # 4. Rewrite everything else to index.html (SPA fallback)
  RewriteRule . /index.html [L]
</IfModule>

# Block all dot-files
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# Block sensitive files
<FilesMatch "(package\.json|package-lock\.json|node_modules)">
  Require all denied
</FilesMatch>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-XSS-Protection "1; mode=block"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>
