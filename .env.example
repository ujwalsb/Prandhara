# =============================================================================
# Prandhara ERP — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# REQUIRED variables (app will crash on startup if missing in production)
# OPTIONAL variables have safe defaults shown in comments
#
# For Hostinger hPanel deployment:
#   Set these variables in hPanel -> Websites -> Node.js -> Environment Variables
#   NODE_ENV must be set to "production" for Hostinger
# =============================================================================

# --- REQUIRED: Database ---
# MongoDB connection string (Atlas or local)
# Local development: mongodb://localhost:27017/newshop20123
# MongoDB Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/newshop20123

# --- REQUIRED: JWT Authentication ---
# Generate a strong random secret (64+ characters recommended):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string

# --- REQUIRED for Production ---
# For Hostinger hPanel deployment, this MUST be "production"
# This enables frontend serving from the backend
NODE_ENV=production

# --- OPTIONAL: JWT ---
# Token expiration duration (default: 7d)
# JWT_EXPIRES_IN=7d

# --- OPTIONAL: Server ---
# Port the backend runs on (Hostinger assigns this automatically; default: 5000)
# PORT=5000

# --- OPTIONAL: Client URL ---
# Frontend URL for CORS headers and email links (default: http://localhost:5173)
# For production: https://yourdomain.com
# CLIENT_URL=https://yourdomain.com

# --- OPTIONAL: Email (SMTP) ---
# Used for sending verification, password reset, and order confirmation emails.
# Gmail example: use an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# --- OPTIONAL: Razorpay (Payments) ---
# Get your keys from: https://dashboard.razorpay.com/app/keys
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=your_razorpay_secret
