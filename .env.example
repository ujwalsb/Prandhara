# =============================================================================
# Prandhara ERP — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# REQUIRED variables (app will crash on startup if missing in production)
# OPTIONAL variables have safe defaults shown in comments
# =============================================================================

# --- REQUIRED: Database ---
# MongoDB connection string (Atlas or local)
# Local: mongodb://localhost:27017/newshop20123
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/newshop20123

# --- REQUIRED: JWT Authentication ---
# Generate a strong random secret (64+ characters recommended):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string

# --- OPTIONAL: JWT ---
# Token expiration duration (default: 7d)
# JWT_EXPIRES_IN=7d

# --- OPTIONAL: Server ---
# Port the backend runs on (default: 5000)
# PORT=5000

# --- OPTIONAL: Node Environment ---
# Set to "production" for production, "development" for local (default: development)
NODE_ENV=development

# --- OPTIONAL: Client URL ---
# Frontend URL for CORS and email links (default: http://localhost:5173)
# CLIENT_URL=http://localhost:5173

# --- OPTIONAL: Email (SMTP) ---
# Used for sending verification, password reset, and order confirmation emails.
# Gmail example: use an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# --- OPTIONAL: Razorpay (Payments) ---
# Get your keys from: https://dashboard.razorpay.com/app/keys
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=your_razorpay_secret
